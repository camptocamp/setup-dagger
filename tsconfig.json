{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": [
		"@tsconfig/strictest/tsconfig.json",
	],
	"compilerOptions": {
		"rootDir": "./src",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"module": "ES2022",
		"noEmit": true,
		"noImplicitAny": true,
		"noFallthroughCasesInSwitch": true,
	}
}

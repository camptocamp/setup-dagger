{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"module": "ES2022",
		"target": "ES2022",
		"moduleResolution": "Bundler",
		"baseUrl": "./",
		"sourceMap": true,
		"noImplicitAny": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"newLine": "lf",
		"noEmit": true,
	}
}
